---
import '../styles/global.css';

const {
  title = 'JAYASINGHE & Co.',
  description = 'Reliable batteries, torches, and LED lighting for homes and businesses.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      // Initial theme setup to avoid FOUC
      (() => {
        const getTheme = () => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          // Default to light
          return 'light';
        };
        const theme = getTheme();
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a href="/" class="logo">
          <span class="dot" />
          <span>JAYASINGHE & Co.</span>
        </a>
        <div class="nav-links">
          <a href="/catalog">Catalog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <div id="theme-toggle-pill" class="theme-pill-toggle" aria-label="Toggle Theme">
            <div class="toggle-knob">
              <span id="knob-icon">☀️</span>
            </div>
            <span id="toggle-text" class="toggle-label">Night</span>
          </div>
        </div>
      </header>
    </div>
    <main class="shell">
      <slot />
    </main>
    <footer>
      <div class="shell">
        <div class="footer-row">
          <div>
            <strong><a href="/">JAYASINGHE & Co.</a></strong><br />
            Batteries, torches, LED fittings, and power accessories.
          </div>
          <div>
            <div>Phone: 0773772177</div>
            <div>Email: jayasinghedistributors@gmail.com</div>
            <div>Mon-Sat, 9:30 AM - 7:30 PM</div>
          </div>
          <div class="footer-credit">
            <img src="/lasal.jpg" onerror="this.src='/lasal.svg'" alt="Lasal Jayasinghe" loading="lazy" />
            <div class="byline">
              <strong>Lasal Jayasinghe</strong>
              <span>Software developed by</span>
            </div>
          </div>
        </div>
      </div>
    </footer>
    <script is:inline>
      const pill = document.getElementById('theme-toggle-pill');
      const knobIcon = document.getElementById('knob-icon');
      const toggleText = document.getElementById('toggle-text');
      
      const updatePill = (theme) => {
        if (theme === 'dark') {
          knobIcon.textContent = '🌙';
          toggleText.textContent = 'Day';
        } else {
          knobIcon.textContent = '☀️';
          toggleText.textContent = 'Night';
        }
      };

      // Set initial state
      updatePill(document.documentElement.getAttribute('data-theme'));

      pill.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        updatePill(newTheme);
      });
    </script>
  </body>
</html>
