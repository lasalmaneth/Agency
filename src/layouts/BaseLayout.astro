---
import '../styles/global.css';

const {
  title = 'BrightArc Energy',
  description = 'Reliable batteries, torches, and LED lighting for homes and businesses.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      // Initial theme setup to avoid FOUC
      (() => {
        const getTheme = () => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };
        const theme = getTheme();
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <div class="logo">
          <span class="dot" />
          <span>BrightArc Energy</span>
        </div>
        <div class="nav-links">
          <span>Catalog</span>
          <span>About</span>
          <span>Contact</span>
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Theme">
            <span class="theme-icon">🌙</span>
          </button>
        </div>
      </header>
    </div>
    <main class="shell">
      <slot />
    </main>
    <footer>
      <div class="shell">
        <div class="footer-row">
          <div>
            <strong>BrightArc Energy</strong><br />
            Batteries, torches, LED fittings, and power accessories.
          </div>
          <div>
            <div>Phone: +91-98765-43210</div>
            <div>Email: hello@brightarc.in</div>
            <div>Mon-Sat, 9:30 AM - 7:30 PM</div>
          </div>
          <div class="footer-credit">
            <img src="/lasal.jpg" onerror="this.src='/lasal.svg'" alt="Lasal Jayasinghe" loading="lazy" />
            <div class="byline">
              <strong>Lasal Jayasinghe</strong>
              <span>Software developed by</span>
            </div>
          </div>
        </div>
      </div>
    </footer>
    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      const themeIcon = themeToggle.querySelector('.theme-icon');
      
      const updateIcon = (theme) => {
        themeIcon.textContent = theme === 'dark' ? '🌙' : '☀️';
      };

      // Set initial icon state
      updateIcon(document.documentElement.getAttribute('data-theme'));

      themeToggle.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        updateIcon(newTheme);
      });
    </script>
  </body>
</html>
