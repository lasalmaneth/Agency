---
import Layout from '../layouts/BaseLayout.astro';
import Layout from '../layouts/BaseLayout.astro';
---
<Layout title="Jayasinghe & Co. | Batteries, Torches, LED" description="Reliable batteries and lighting for homes, offices, field teams, and retail.">
  <div class="animated-distributor">
    <span class="distributor-text">JAYASINGHE DISTRIBUTORS</span>
  </div>
  <div class="distributor-banner" style="width: 100vw; margin-bottom: 2.5rem; overflow: hidden; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw;">
    <img src="/toshiba-banner.jpg" alt="Toshiba Power Solutions Banner" style="width: 100vw; max-width: 100vw; height: auto; display: block; margin-left: 50%; transform: translateX(-50%); border-radius: 18px; box-shadow: 0 4px 32px rgba(0,0,0,0.18); object-fit: contain;" />
  </div>
  <section class="hero">
    <div class="pill">Trusted supply • Fast response • Pan-city delivery</div>
    <h1>Jayasinghe & Co.: batteries, torches, and LED lighting that stay on when it matters.</h1>
    <p>
      We stock automotive and solar batteries, high-output torches, and efficient LED fixtures. Specs, pricing,
      and ready inventory for quick dispatch.
    </p>
    <div class="cta-row">
      <a class="btn primary" href="/catalog">View catalog</a>
      <a class="btn" href="mailto:jayasinghedistributors@gmail.com">Request a quote</a>
      <a class="btn" href="tel:0773772177">Call now</a>
    </div>
    <div class="stat-row">
      <div class="stat">
        <div class="label">Same-day dispatch</div>
        <div class="value">Before 4:00 PM</div>
      </div>
      <div class="stat">
        <div class="label">Warranty support</div>
        <div class="value">Authorized partner</div>
      </div>
      <div class="stat">
        <div class="label">Bulk pricing</div>
        <div class="value">Tiered discounts</div>
      </div>
      <div class="stat">
        <div class="label">Delivery radius</div>
        <div class="value">City + 60 km</div>
      </div>
    </div>
  </section>

  <section id="contact">
    <div class="section-head">
      <div>
        <h2>Need a bulk quote?</h2>
        <p>Share your requirement; we respond within 60 minutes during business hours.</p>
      </div>
    </div>
    <div class="card" style="display: grid; gap: 10px;">
      <div><strong>Phone:</strong> 0773772177</div>
      <div><strong>Email:</strong> jayasinghedistributors@gmail.com</div>
      <div><strong>Store hours:</strong> Mon-Sat, 9:30 AM - 7:30 PM</div>
      <div><strong>Dispatch:</strong> Same day for in-stock items before 4 PM</div>
    </div>
  </section>

</Layout>
