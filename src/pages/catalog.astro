---
import BaseLayout from '../layouts/BaseLayout.astro';

// Top-level battery types to show first
const batteryTypes = [
  { key: 'all', name: 'All Batteries', icon: '📚', desc: 'View our full battery range' },
  { key: 'abc', name: 'ABC Batteries', icon: '🏭', desc: 'Manufactured by JAYASINGHE & Co.' },
  { key: 'toshiba', name: 'Toshiba Batteries', icon: '🔋', desc: 'Toshiba high-performance cells' }
];

// Subcategories shown after selecting a top-level type
const batterySubRanges = [
  { id: 'aa', name: 'AA', icon: '🔋', desc: 'Standard double-A for remotes and toys' },
  { id: 'aaa', name: 'AAA', icon: '🪫', desc: 'Triple-A for small electronics' },
  { id: '9v', name: '9V', icon: '🔌', desc: 'High voltage for smoke detectors' },
  { id: 'r14', name: 'R14 (C)', icon: '📦', desc: 'Medium size for high-drain devices' },
  { id: 'r20', name: 'R20 (D)', icon: '🛢️', desc: 'Large size for flashlights and stereos' }
];

const torchRanges = [
  { name: 'Table Lamps', icon: '💡', desc: 'Decorative and desk lighting for homes and offices' },
  { name: 'Dolphin Torches', icon: '🐬', desc: 'Slim, curved-design torches with ergonomic grip' },
  { name: 'Mini Torches', icon: '🔦', desc: 'Compact pocket-sized LED torches' },
  { name: 'Budget Torches', icon: '💸', desc: 'Affordable everyday-use lights' },
  { name: 'Heavy Duty', icon: '🚨', desc: 'Industrial grade spotlights' },
  { name: 'Camping', icon: '🏕️', desc: 'Lanterns and tent lights' }
];

const ledRanges = [
  { name: 'Panel Lights', icon: '🖼️', desc: 'Sleek ceiling lighting solutions' },
  { name: 'High Bay', icon: '🏭', desc: 'Powerful lighting for warehouses' },
  { name: 'Street Lights', icon: '🛣️', desc: 'Outdoor and municipal lighting' }
];
---

<BaseLayout title="Catalog - JAYASINGHE & Co.">
  <div class="hero">
    <h1>Product Catalog</h1>
    <p>Select a category to explore our specialized ranges.</p>
  </div>

  <div class="catalog-view">
    <!-- Initial Selection View -->
    <div id="selection-view" class="selection-grid">
      <div class="selection-card" data-category="batteries">
        <img src="/images/toshiba.png" alt="Toshiba Batteries" />
        <div class="selection-overlay">
          <h3>Batteries</h3>
          <p>Toshiba Power Solutions</p>
        </div>
      </div>
      
      <div class="selection-card" data-category="torches">
        <img src="/images/lumi.png" alt="Master Torches" />
        <div class="selection-overlay">
          <h3>Torches</h3>
          <p>Master Professional Flashlights</p>
        </div>
      </div>

      <div class="selection-card" data-category="led">
        <img src="/images/neco.png" alt="Neco LED Lighting" />
        <div class="selection-overlay">
          <h3>LED Lighting</h3>
          <p>Neco Architectural IlMasternation</p>
        </div>
      </div>
    </div>

    <!-- Category Detail Views (Hidden by default) -->
    <div id="detail-view" style="display: none;">
      <button id="back-to-selection" class="back-btn">
        <span>← Back to Categories</span>
      </button>

      <!-- Batteries Content -->
      <div class="category-content" id="content-batteries" style="display: none;">
        <div class="section-head">
          <div>
            <h2 id="batteries-heading">Battery Ranges</h2>
            <p id="batteries-subhead">Featuring Toshiba high-performance cells.</p>
          </div>
        </div>

        <!-- Top-level battery types (shown first) -->
        <div id="battery-types" class="range-grid types-grid">
          {batteryTypes.map(type => (
            <div class="range-card battery-type" data-key={type.key}>
              <span class="range-icon">{type.icon}</span>
              <span class="range-name">{type.name}</span>
              <span class="range-desc">{type.desc}</span>
            </div>
          ))}
        </div>

        <!-- Subcategories (hidden until a type is selected) -->
        <div id="battery-subranges" style="display: none;">
          <button id="back-to-types" class="back-btn small">← Back to Battery Types</button>
          <div class="range-grid subrange-grid">
            {batterySubRanges.map(range => (
              <div class="range-card subrange-card" data-id={range.id}>
                <span class="range-icon">{range.icon}</span>
                <span class="range-name">{range.name}</span>
                <span class="range-desc">{range.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Torches Content -->
      <div class="category-content" id="content-torches" style="display: none;">
        <div class="section-head">
          <div>
            <h2>Torch Varieties</h2>
            <p>Premium Master lighting equipment.</p>
          </div>
        </div>
        <div class="range-grid">
          {torchRanges.map(range => (
            <div class="range-card">
              <span class="range-icon">{range.icon}</span>
              <span class="range-name">{range.name}</span>
              <span class="range-desc">{range.desc}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- LED Content -->
      <div class="category-content" id="content-led" style="display: none;">
        <div class="section-head">
          <div>
            <h2>LED Solutions</h2>
            <p>Innovative Neco architectural lighting.</p>
          </div>
        </div>
        <div class="range-grid">
          {ledRanges.map(range => (
            <div class="range-card">
              <span class="range-icon">{range.icon}</span>
              <span class="range-name">{range.name}</span>
              <span class="range-desc">{range.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const selectionView = document.getElementById('selection-view');
    const detailView = document.getElementById('detail-view');
    const backBtn = document.getElementById('back-to-selection');
    const cards = document.querySelectorAll('.selection-card');
    const contents = document.querySelectorAll('.category-content');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const category = card.getAttribute('data-category');
        
        selectionView.style.display = 'none';
        detailView.style.display = 'block';
        
        contents.forEach(content => {
          content.style.display = content.id === `content-${category}` ? 'block' : 'none';
        });
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });

    backBtn.addEventListener('click', () => {
      detailView.style.display = 'none';
      selectionView.style.display = 'grid';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Battery types -> show subcategories when a type is selected
    const batteryTypesEls = document.querySelectorAll('.battery-type');
    const batteryTypesWrap = document.getElementById('battery-types');
    const batterySubranges = document.getElementById('battery-subranges');
    const batteriesHeading = document.getElementById('batteries-heading');
    const batteriesSubhead = document.getElementById('batteries-subhead');
    const backToTypesBtn = document.getElementById('back-to-types');

    batteryTypesEls.forEach(el => {
      el.addEventListener('click', () => {
        // update heading based on selection
        const name = el.querySelector('.range-name').textContent;
        batteriesHeading.textContent = `${name} — Categories`;
        batteriesSubhead.textContent = `Select a size or type under ${name}.`;

        // show subranges and hide top types
        batteryTypesWrap.style.display = 'none';
        batterySubranges.style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });

    backToTypesBtn?.addEventListener('click', () => {
      // restore original heading
      batteriesHeading.textContent = 'Battery Ranges';
      batteriesSubhead.textContent = 'Featuring Toshiba high-performance cells.';
      batterySubranges.style.display = 'none';
      batteryTypesWrap.style.display = 'grid';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
</BaseLayout>
